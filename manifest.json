{
  "manifest_version": 3,
  "name": "LinkedIn Anti Refresh",
  "version": "1.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "xxx",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "Verhindert, dass LinkedIn den Feed beim Tab-Wechsel neu lädt.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["script.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/alr16.png",
    "96": "icons/alr96.png",
    "32": "icons/alr32.png"
  }
}
